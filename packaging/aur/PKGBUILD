# Maintainer: Benjamin Lang <beni@lbau.org>
pkgname=tspdf
pkgver=0.4.0
pkgrel=1
pkgdesc="Zero-dependency PDF toolkit and CLI in pure C11"
arch=('x86_64' 'aarch64')
url="https://github.com/be-lang/tspdf"
license=('MIT')
depends=('glibc')
# libtspdf.a is installed alongside the shared lib; without this makepkg
# would strip it.
options=('staticlibs')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('9b17bc57218d5b727fa968f7e6a911e9802f46cf721d7c9933f5789826d8c5b1')

build() {
    cd "$pkgname-$pkgver"
    make
    # Build the libraries here too (`make install` needs them), so package()
    # only copies files and compiles nothing under fakeroot.
    make lib shared
}

check() {
    cd "$pkgname-$pkgver"
    make test
}

package() {
    cd "$pkgname-$pkgver"
    make DESTDIR="$pkgdir" PREFIX=/usr install
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
